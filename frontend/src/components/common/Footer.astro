---
const currentYear = new Date().getFullYear();
---

<footer
    class="bg-slate-50 dark:bg-slate-900 border-t border-slate-200 dark:border-slate-700"
>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- About -->
            <div>
                <h3 class="font-semibold text-slate-900 dark:text-white mb-3">
                    JobPulse
                </h3>
                <p class="text-sm text-slate-600 dark:text-slate-400">
                    Aggregating job listings from LinkedIn and Indeed to help
                    you find your next opportunity.
                </p>
            </div>

            <!-- Quick Links -->
            <div>
                <h3 class="font-semibold text-slate-900 dark:text-white mb-3">
                    Quick Links
                </h3>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a
                            href="/jobs"
                            class="text-slate-600 hover:text-primary-600 dark:text-slate-400 dark:hover:text-primary-400"
                            >Browse Jobs</a>
                    </li>
                    <li>
                        <a
                            href="/companies"
                            class="text-slate-600 hover:text-primary-600 dark:text-slate-400 dark:hover:text-primary-400"
                            >Companies</a>
                    </li>
                    <li>
                        <a
                            href="/analytics"
                            class="text-slate-600 hover:text-primary-600 dark:text-slate-400 dark:hover:text-primary-400"
                            >Analytics</a>
                    </li>
                </ul>
            </div>

            <!-- Sources -->
            <div>
                <h3 class="font-semibold text-slate-900 dark:text-white mb-3">
                    Data Sources
                </h3>
                <div class="flex gap-3">
                    <span class="px-3 py-1 text-sm rounded-full source-linkedin"
                        >LinkedIn</span
                    >
                    <span class="px-3 py-1 text-sm rounded-full source-indeed"
                        >Indeed</span
                    >
                </div>
            </div>
        </div>

        <div
            class="mt-8 pt-6 border-t border-slate-200 dark:border-slate-700 text-center text-sm text-slate-500"
        >
            <p>&copy; {currentYear} JobPulse. Built with Astro + Go.</p>
        </div>
    </div>
</footer>
