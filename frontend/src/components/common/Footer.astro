---
import BrandMark from "./BrandMark.astro";

const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--jh-ink)] text-white">
    <div class="mx-auto max-w-[1180px] px-6 py-20">
        <div class="grid gap-14 lg:grid-cols-[1.2fr_0.55fr_0.55fr_1fr]">
            <div>
                <BrandMark light />
                <p class="mt-8 max-w-[22rem] text-lg leading-9 text-slate-300">
                    Great platform for the job seeker that passionate about startups. Find your dream job easier.
                </p>
            </div>
            <div>
                <h3 class="text-[1.65rem] font-bold tracking-[-0.04em]">About</h3>
                <ul class="mt-6 space-y-4 text-lg text-slate-300">
                    <li><a href="/companies" class="hover:text-white">Companies</a></li>
                    <li><a href="/jobs" class="hover:text-white">Pricing</a></li>
                    <li><a href="/jobs" class="hover:text-white">Terms</a></li>
                    <li><a href="/analytics" class="hover:text-white">Advice</a></li>
                    <li><a href="/auth/register" class="hover:text-white">Privacy Policy</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-[1.65rem] font-bold tracking-[-0.04em]">Resources</h3>
                <ul class="mt-6 space-y-4 text-lg text-slate-300">
                    <li><a href="/analytics" class="hover:text-white">Help Docs</a></li>
                    <li><a href="/jobs" class="hover:text-white">Guide</a></li>
                    <li><a href="/analytics" class="hover:text-white">Updates</a></li>
                    <li><a href="/companies" class="hover:text-white">Contact Us</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-[1.65rem] font-bold tracking-[-0.04em]">Get job notifications</h3>
                <p class="mt-6 text-lg leading-9 text-slate-300">
                    The latest job news, articles, sent to your inbox weekly.
                </p>
                <form class="mt-8 flex overflow-hidden rounded-[1.35rem] bg-white">
                    <input
                        type="email"
                        placeholder="Email Address"
                        class="min-w-0 flex-1 bg-transparent px-5 py-4 text-lg text-slate-900 outline-none"
                    />
                    <button type="submit" class="bg-[var(--jh-primary)] px-6 py-4 text-lg font-semibold text-white">Subscribe</button>
                </form>
            </div>
        </div>

        <div class="mt-16 border-t border-white/10 pt-10 text-base text-slate-400">
            <p>2021 @ JobHuntly. All rights reserved. Updated {currentYear}.</p>
        </div>
    </div>
</footer>
