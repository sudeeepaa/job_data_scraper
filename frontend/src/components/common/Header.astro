---
import AuthNav from "../islands/AuthNav";
import BrandMark from "./BrandMark.astro";

const navLinks = [
    { href: "/jobs", label: "Find Jobs" },
    { href: "/companies", label: "Browse Companies" },
    { href: "/tracker", label: "Tracker" },
    { href: "/analytics", label: "Insights" },
];

const currentPath = Astro.url.pathname;
---

<header class="glass sticky top-0 z-50">
    <nav class="mx-auto flex h-20 max-w-[1240px] items-center justify-between px-6">
        <BrandMark />
        <div class="hidden items-center gap-8 lg:flex">
            {
                navLinks.map((link) => (
                    <a
                        href={link.href}
                        class:list={[
                            "text-base font-semibold tracking-tight transition-all hover:text-[var(--jp-accent)]",
                            currentPath === link.href ||
                            (link.href !== "/" && currentPath.startsWith(link.href))
                                ? "text-[var(--jp-accent)]"
                                : "text-[var(--jp-text-muted)]",
                        ]}
                    >
                        {link.label}
                    </a>
                ))
            }
        </div>
        <div class="hidden items-center gap-6 lg:flex">
            <AuthNav client:load />
        </div>
        <button
            type="button"
            class="rounded-xl border border-[var(--jp-border)] p-2.5 text-[var(--jp-text-primary)] transition-colors hover:bg-[var(--jp-surface)] lg:hidden"
            aria-label="Open menu"
            id="mobile-menu-btn"
        >
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path>
            </svg>
        </button>
    </nav>
    <div class="hidden border-t border-[var(--jp-border)] bg-[var(--jp-surface)]/95 backdrop-blur-lg lg:hidden" id="mobile-menu">
        <div class="mx-auto flex flex-col gap-4 px-6 py-8">
            {
                navLinks.map((link) => (
                    <a
                        href={link.href}
                        class="text-lg font-semibold text-[var(--jp-text-primary)] hover:text-[var(--jp-accent)] transition-colors"
                    >
                        {link.label}
                    </a>
                ))
            }
            <div class="mt-4 flex flex-col gap-4 pt-4 border-t border-[var(--jp-border)]">
                <AuthNav client:load />
            </div>
        </div>
    </div>
</header>

<script>
    const menuBtn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");

    menuBtn?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
    });
</script>
