---
import AuthNav from "../islands/AuthNav";
import BrandMark from "./BrandMark.astro";

const navLinks = [
    { href: "/jobs", label: "Find Jobs" },
    { href: "/companies", label: "Browse Companies" },
    { href: "/analytics", label: "Insights" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/92 backdrop-blur">
    <nav class="mx-auto flex h-24 max-w-[1180px] items-center justify-between px-6">
        <BrandMark />
        <div class="hidden items-center gap-10 lg:flex">
            {
                navLinks.map((link) => (
                    <a
                        href={link.href}
                        class:list={[
                            "border-b-[3px] pb-4 text-lg font-semibold tracking-[-0.03em] transition-colors",
                            currentPath === link.href ||
                            (link.href !== "/" && currentPath.startsWith(link.href))
                                ? "border-[var(--jh-primary)] text-[var(--jh-primary)]"
                                : "border-transparent text-slate-500 hover:text-slate-900",
                        ]}
                    >
                        {link.label}
                    </a>
                ))
            }
        </div>
        <div class="hidden items-center gap-5 lg:flex">
            <AuthNav client:load />
            <a href="/auth/register" class="jh-button">Sign Up</a>
        </div>
        <button
            type="button"
            class="rounded-2xl border border-slate-200 p-3 text-slate-700 lg:hidden"
            aria-label="Open menu"
            id="mobile-menu-btn"
        >
            <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path>
            </svg>
        </button>
    </nav>
    <div class="hidden border-t border-slate-200 bg-white lg:hidden" id="mobile-menu">
        <div class="mx-auto flex max-w-[1180px] flex-col gap-5 px-6 py-6">
            {
                navLinks.map((link) => (
                    <a
                        href={link.href}
                        class:list={[
                            "text-lg font-semibold tracking-[-0.03em]",
                            currentPath === link.href ||
                            (link.href !== "/" && currentPath.startsWith(link.href))
                                ? "text-[var(--jh-primary)]"
                                : "text-slate-600",
                        ]}
                    >
                        {link.label}
                    </a>
                ))
            }
            <div class="flex items-center gap-4">
                <AuthNav client:load />
                <a href="/auth/register" class="jh-button">Sign Up</a>
            </div>
        </div>
    </div>
</header>

<script>
    const menuBtn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");

    menuBtn?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
    });
</script>
