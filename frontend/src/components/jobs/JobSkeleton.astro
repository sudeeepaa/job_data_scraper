---
interface Props {
    mode?: "grid" | "list";
}

const { mode = "grid" } = Astro.props;
const isGrid = mode === "grid";
---

<div
    class:list={[
        "glass-card animate-pulse relative overflow-hidden",
        isGrid ? "flex h-full flex-col p-6 rounded-3xl" : "grid gap-6 p-6 lg:grid-cols-[1fr_auto] rounded-2xl",
    ]}
>
    <div class:list={[isGrid ? "flex h-full flex-col" : "flex min-w-0 items-start gap-4"]}>
        <div class="flex items-start gap-4">
            <div class="h-12 w-12 shrink-0 rounded-2xl bg-[var(--jp-border)]"></div>
            <div class="min-w-0 flex-1">
                <div class="mb-2 h-3 w-24 rounded bg-[var(--jp-border)]"></div>
                <div class:list={[
                    "h-6 rounded bg-[var(--jp-border)] mb-2",
                    isGrid ? "w-3/4" : "w-1/2",
                ]}></div>
                <div class="h-4 w-1/3 rounded bg-[var(--jp-border)]"></div>
            </div>
        </div>

        <div class:list={[isGrid ? "mt-6 flex-1" : "min-w-0 flex-1"]}>
            <div class="flex flex-wrap gap-2">
                <div class="h-6 w-16 rounded-full bg-[var(--jp-border)]"></div>
                <div class="h-6 w-20 rounded-full bg-[var(--jp-border)]"></div>
                <div class="h-6 w-14 rounded-full bg-[var(--jp-border)]"></div>
            </div>
            {isGrid && (
                <div class="mt-4 space-y-2">
                    <div class="h-3 w-full rounded bg-[var(--jp-border)]"></div>
                    <div class="h-3 w-full rounded bg-[var(--jp-border)]"></div>
                    <div class="h-3 w-2/3 rounded bg-[var(--jp-border)]"></div>
                </div>
            )}
        </div>
    </div>

    <div class:list={[isGrid ? "mt-6 pt-5 border-t border-[var(--jp-border)]" : "flex flex-col items-end justify-between gap-4 lg:min-w-[14rem]"]}>
        <div class:list={[isGrid ? "flex items-center justify-between" : "text-right"]}>
            <div class="flex flex-col gap-2">
                <div class="h-6 w-24 rounded bg-[var(--jp-border)]"></div>
                <div class="h-3 w-32 rounded bg-[var(--jp-border)]"></div>
            </div>
            {isGrid && <div class="h-8 w-8 rounded-full bg-[var(--jp-border)]"></div>}
        </div>
        {!isGrid && <div class="h-10 w-32 rounded-xl bg-[var(--jp-border)]"></div>}
    </div>
</div>
