---
import PageLayout from "../../layouts/PageLayout.astro";
import JobCard from "../../components/jobs/JobCard.astro";
import SaveJobButton from "../../components/islands/SaveJobButton";
import { fetchCompany, fetchJob } from "../../lib/api";
import { formatAbsoluteDate, formatSalaryRange, getInitials, sourceLabel } from "../../lib/job-ui";

const { id } = Astro.params;

let job = null;
let similarJobs = [];
let company = null;
let error = null;

try {
    if (id) {
        job = await fetchJob(id);
        if (job?.companySlug) {
            const companyResponse = await fetchCompany(job.companySlug);
            company = companyResponse.company;
            similarJobs = companyResponse.jobs.filter((item) => item.id !== job.id).slice(0, 4);
        }
    }
} catch (e) {
    error = e instanceof Error ? e.message : "Failed to load job";
}

const salary = job ? formatSalaryRange(job) : null;
const descriptionSections = job
    ? job.description
          .split(/\n\s*\n/)
          .map((block) => block.trim())
          .filter(Boolean)
          .map((block) => {
              const lines = block
                  .split("\n")
                  .map((line) => line.trim())
                  .filter(Boolean);

              const bulletLines = lines
                  .filter((line) => /^[-*•]/.test(line))
                  .map((line) => line.replace(/^[-*•]\s*/, "").trim())
                  .filter(Boolean);

              if (bulletLines.length >= 2 && bulletLines.length === lines.length) {
                  return { kind: "list", items: bulletLines };
              }

              return { kind: "paragraph", text: lines.join(" ") };
          })
    : [];
---

<PageLayout title={job ? `${job.title} at ${job.company}` : "Job Not Found"} description={job ? job.description : "Job detail page"}>
    <section class="border-b border-slate-200 bg-[linear-gradient(180deg,#f3f6ff_0%,#fbfcff_100%)]">
        <div class="mx-auto max-w-[1180px] px-6 py-12">
            <a href="/jobs" class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--jh-primary)]">Back to jobs</a>
            {job && (
                <div class="jh-card mt-8 flex flex-col gap-6 p-8 lg:flex-row lg:items-center lg:justify-between">
                    <div class="flex min-w-0 items-start gap-5">
                        <div class="flex h-20 w-20 items-center justify-center rounded-[1.6rem] bg-[linear-gradient(135deg,#e9ecff_0%,#635bff_100%)] text-3xl font-extrabold text-white">
                            {getInitials(job.company)}
                        </div>
                        <div class="min-w-0">
                            <h1 class="break-words text-[2.4rem] font-extrabold leading-tight tracking-[-0.06em] text-slate-900 sm:text-[3rem]">{job.title}</h1>
                            <div class="mt-3 break-words text-lg text-slate-500">{job.company} • {job.location} • {job.employmentType}</div>
                            <div class="mt-4 flex flex-wrap gap-3">
                                <span class="jh-tag jh-tag-marketing">{job.skills[0] || job.experienceLevel}</span>
                                <span class="jh-tag jh-tag-design">{sourceLabel(job.source)}</span>
                            </div>
                        </div>
                    </div>
                    <div class="flex shrink-0 flex-wrap items-center gap-3">
                        <SaveJobButton client:load jobId={job.id} initialSaved={job.isSaved} />
                        <a href={job.sourceUrl} target="_blank" rel="noreferrer" class="jh-button px-8 py-4">Apply</a>
                    </div>
                </div>
            )}
        </div>
    </section>

    <section class="mx-auto max-w-[1180px] px-6 py-14">
        {error ? (
            <div class="rounded-[1.5rem] border border-[rgba(255,108,95,0.28)] bg-[rgba(255,108,95,0.08)] p-6 text-lg font-medium text-[var(--jh-coral)]">
                {error}
            </div>
        ) : job && (
            <>
                <div class="grid gap-10 lg:grid-cols-[minmax(0,1.25fr)_20rem] xl:grid-cols-[minmax(0,1.35fr)_21rem]">
                    <div class="space-y-8 min-w-0">
                        <div class="jh-card p-8">
                            <h2 class="text-[2.3rem] font-extrabold tracking-[-0.06em] text-slate-900">Description</h2>
                            <div class="mt-6 space-y-5">
                                {descriptionSections.map((section) => (
                                    section.kind === "list" ? (
                                        <ul class="space-y-3 text-base leading-8 text-slate-600">
                                            {section.items.map((item) => (
                                                <li class="flex gap-3">
                                                    <span class="mt-2 inline-block h-2.5 w-2.5 shrink-0 rounded-full bg-[var(--jh-primary)]"></span>
                                                    <span>{item}</span>
                                                </li>
                                            ))}
                                        </ul>
                                    ) : (
                                        <p class="max-w-[72ch] text-base leading-8 text-slate-600">{section.text}</p>
                                    )
                                ))}
                                {descriptionSections.length === 0 && (
                                    <p class="max-w-[72ch] text-base leading-8 text-slate-600">{job.description}</p>
                                )}
                            </div>
                        </div>
                    </div>

                    <aside class="space-y-6 lg:sticky lg:top-30 lg:self-start">
                        <div class="jh-card p-8">
                            <h2 class="text-[1.75rem] font-extrabold tracking-[-0.06em] text-slate-900">About this role</h2>
                            <div class="mt-6 h-2 overflow-hidden rounded-full bg-[var(--jh-soft)]">
                                <div class="h-full w-2/5 rounded-full bg-[linear-gradient(90deg,#58d6be_0%,#8ae4d1_100%)]"></div>
                            </div>
                            <div class="mt-6 space-y-4 text-sm text-slate-600 sm:text-base">
                                <div class="flex items-center justify-between gap-4">
                                    <span>Apply before</span>
                                    <span class="font-semibold text-slate-900">{job.expiresAt ? formatAbsoluteDate(job.expiresAt) : "Open now"}</span>
                                </div>
                                <div class="flex items-center justify-between gap-4">
                                    <span>Job posted on</span>
                                    <span class="font-semibold text-slate-900">{formatAbsoluteDate(job.postedAt)}</span>
                                </div>
                                <div class="flex items-center justify-between gap-4">
                                    <span>Job type</span>
                                    <span class="font-semibold text-slate-900">{job.employmentType}</span>
                                </div>
                                <div class="flex items-center justify-between gap-4">
                                    <span>Salary</span>
                                    <span class="font-semibold text-slate-900">{salary || "Competitive"}</span>
                                </div>
                                <div class="flex items-center justify-between gap-4">
                                    <span>Source</span>
                                    <span class="font-semibold text-slate-900">{sourceLabel(job.source)}</span>
                                </div>
                            </div>
                        </div>

                        <div class="jh-card p-8">
                            <h2 class="text-[1.75rem] font-extrabold tracking-[-0.06em] text-slate-900">Required skills</h2>
                            <div class="mt-5 flex flex-wrap gap-3">
                                {job.skills.length > 0 ? job.skills.map((skill, index) => (
                                    <span class:list={["jh-tag max-w-full truncate", index % 2 === 0 ? "jh-tag-design" : "jh-tag-business"]} title={skill}>{skill}</span>
                                )) : (
                                    <span class="text-base text-slate-500">No skill tags provided for this listing.</span>
                                )}
                            </div>
                        </div>

                        {company && (
                            <div class="jh-card p-8">
                                <div class="flex items-center gap-4">
                                    <div class="flex h-16 w-16 items-center justify-center rounded-[1.2rem] bg-[linear-gradient(135deg,#e9ecff_0%,#635bff_100%)] text-2xl font-extrabold text-white">
                                        {getInitials(company.name)}
                                    </div>
                                    <div>
                                        <div class="text-[1.5rem] font-extrabold tracking-[-0.05em] text-slate-900">{company.name}</div>
                                        <a href={`/companies/${company.slug}`} class="mt-1 inline-block text-base font-semibold text-[var(--jh-primary)]">Read company profile →</a>
                                    </div>
                                </div>
                                <p class="mt-5 text-base leading-7 text-slate-500">{company.description}</p>
                            </div>
                        )}
                    </aside>
                </div>

                {similarJobs.length > 0 && (
                    <div class="mt-14">
                        <div class="mb-8 flex items-end justify-between gap-4">
                            <h2 class="text-[2.4rem] font-extrabold tracking-[-0.06em] text-slate-900">Similar Jobs</h2>
                            <a href="/jobs" class="text-lg font-semibold text-[var(--jh-primary)]">Show all jobs →</a>
                        </div>
                        <div class="grid gap-6 lg:grid-cols-2">
                            {similarJobs.map((item) => <JobCard job={item} mode="list" />)}
                        </div>
                    </div>
                )}
            </>
        )}
    </section>
</PageLayout>
