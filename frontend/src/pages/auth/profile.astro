---
import PageLayout from "../../layouts/PageLayout.astro";
import ProfileView from "../../components/islands/ProfileView";
---

<PageLayout title="Profile" description="Your JobPulse profile and saved jobs">
    <section class="mx-auto max-w-[1180px] px-6 py-14">
        <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6 animate-in">
            <div>
                <h1 class="text-5xl md:text-7xl font-bold tracking-tighter text-[var(--jp-text-primary)]">My <span class="text-[var(--jp-accent)]">Profile</span></h1>
                <p class="mt-4 text-xl text-[var(--jp-text-muted)] font-medium">Your personal JobPulse dashboard and saved opportunities.</p>
            </div>
            <a href="/" class="group text-lg font-bold text-[var(--jp-accent)] flex items-center gap-2">
                Back to homepage
                <span class="transition-transform group-hover:translate-x-1">→</span>
            </a>
        </div>
        <ProfileView client:load />
    </section>
</PageLayout>
