---
import PageLayout from "../../layouts/PageLayout.astro";
import ProfileView from "../../components/islands/ProfileView";
---

<PageLayout title="Profile" description="Your JobHuntly profile and saved jobs">
    <section class="mx-auto max-w-[1180px] px-6 py-14">
        <div class="mb-10 flex items-center justify-between gap-4">
            <div>
                <h1 class="text-6xl font-extrabold tracking-[-0.07em] text-slate-900">My Profile</h1>
                <p class="mt-3 text-xl text-slate-500">Your public-facing JobHuntly profile and saved opportunities.</p>
            </div>
            <a href="/" class="jh-button-secondary px-6 py-4">Back to homepage</a>
        </div>
        <ProfileView client:load />
    </section>
</PageLayout>
