---
import PageLayout from '../layouts/PageLayout.astro';
import SkillsChart from '../components/islands/SkillsChart';
import TrendsChart from '../components/islands/TrendsChart';
import SourcesChart from '../components/islands/SourcesChart';
import { fetchTopSkills, fetchAnalyticsSummary, fetchMarketTrends, fetchSourceDistribution, fetchSalaryStats } from '../lib/api';
import type { SkillCount, AnalyticsSummary, MarketTrend, SourceDistribution, SalaryStats } from '../types';

let skills: SkillCount[] = [];
let summary: AnalyticsSummary | null = null;
let trends: MarketTrend[] = [];
let sources: SourceDistribution[] = [];
let salaryStats: SalaryStats | null = null;
let error = null;

try {
  const [skillsResponse, summaryResponse, trendsResponse, sourcesResponse, salaryResponse] = await Promise.all([
    fetchTopSkills(15),
    fetchAnalyticsSummary(),
    fetchMarketTrends(15),
    fetchSourceDistribution(),
    fetchSalaryStats(),
  ]);
  skills = skillsResponse.data;
  summary = summaryResponse;
  trends = trendsResponse.data;
  sources = sourcesResponse.data;
  salaryStats = salaryResponse;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load analytics';
}

const formatSalary = (amount: number) => {
  return new Intl.NumberFormat('en-US', { 
    style: 'currency', 
    currency: 'USD', 
    maximumFractionDigits: 0 
  }).format(amount);
};
---

<PageLayout 
  title="Analytics" 
  description="Job market analytics and insights - trending skills, salary data, and more"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">Market Analytics</h1>
        <p class="text-slate-600 dark:text-slate-400">Insights from aggregated job data</p>
      </div>
      <form method="POST" action="/api/v1/analytics/refresh">
        <button 
          type="button"
          id="refresh-btn"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-primary-600 dark:text-primary-400 bg-primary-50 dark:bg-primary-900/20 border border-primary-200 dark:border-primary-800 rounded-lg hover:bg-primary-100 dark:hover:bg-primary-900/40 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Refresh Data
        </button>
      </form>
    </div>
    
    {error ? (
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-6 text-center">
        <p class="text-red-600 dark:text-red-400">{error}</p>
        <p class="text-sm text-red-500 mt-2">Make sure the backend API is available.</p>
      </div>
    ) : (
      <>
        <!-- Summary Stats -->
        {summary && (
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
            <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-6">
              <div class="text-sm text-slate-500 dark:text-slate-400 mb-1">Total Jobs</div>
              <div class="text-3xl font-bold text-slate-900 dark:text-white">{summary.totalJobs}</div>
            </div>
            <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-6">
              <div class="text-sm text-slate-500 dark:text-slate-400 mb-1">Companies</div>
              <div class="text-3xl font-bold text-slate-900 dark:text-white">{summary.totalCompanies}</div>
            </div>
            <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-6">
              <div class="text-sm text-slate-500 dark:text-slate-400 mb-1">Average Salary</div>
              <div class="text-3xl font-bold text-green-600 dark:text-green-400">{formatSalary(summary.averageSalary)}</div>
            </div>
            <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-6">
              <div class="text-sm text-slate-500 dark:text-slate-400 mb-1">Remote Jobs</div>
              <div class="text-3xl font-bold text-slate-900 dark:text-white">{summary.remoteJobsCount}</div>
              <div class="text-sm text-slate-500">({Math.round((summary.remoteJobsCount / summary.totalJobs) * 100)}% of total)</div>
            </div>
            <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-6">
              <div class="text-sm text-slate-500 dark:text-slate-400 mb-1">Posted This Week</div>
              <div class="text-3xl font-bold text-primary-600 dark:text-primary-400">{summary.jobsThisWeek}</div>
            </div>
            <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-6">
              <div class="text-sm text-slate-500 dark:text-slate-400 mb-1">Posted Today</div>
              <div class="text-3xl font-bold text-slate-900 dark:text-white">{summary.jobsToday}</div>
            </div>
          </div>
        )}

        <!-- Salary Stats -->
        {salaryStats && (
          <div class="mb-8">
            <h2 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">💰 Salary Overview</h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
              <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 border border-green-200 dark:border-green-800 rounded-xl p-6">
                <div class="text-sm text-green-700 dark:text-green-400 mb-1">Minimum</div>
                <div class="text-2xl font-bold text-green-800 dark:text-green-300">{formatSalary(salaryStats.minSalary)}</div>
              </div>
              <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 border border-green-200 dark:border-green-800 rounded-xl p-6">
                <div class="text-sm text-green-700 dark:text-green-400 mb-1">Maximum</div>
                <div class="text-2xl font-bold text-green-800 dark:text-green-300">{formatSalary(salaryStats.maxSalary)}</div>
              </div>
              <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 border border-green-200 dark:border-green-800 rounded-xl p-6">
                <div class="text-sm text-green-700 dark:text-green-400 mb-1">Median</div>
                <div class="text-2xl font-bold text-green-800 dark:text-green-300">{formatSalary(salaryStats.medianSalary)}</div>
              </div>
              <div class="bg-gradient-to-br from-green-50 to-emerald-50 dark:from-green-900/20 dark:to-emerald-900/20 border border-green-200 dark:border-green-800 rounded-xl p-6">
                <div class="text-sm text-green-700 dark:text-green-400 mb-1">With Salary Data</div>
                <div class="text-2xl font-bold text-green-800 dark:text-green-300">{salaryStats.totalWithSalary} jobs</div>
              </div>
            </div>
          </div>
        )}
        
        <!-- Charts Row: Trends + Sources -->
        <div class="grid lg:grid-cols-3 gap-8 mb-8">
          <div class="lg:col-span-2">
            <TrendsChart client:visible trends={trends} title="🔥 Trending Skills (with salary data)" />
          </div>
          <div>
            <SourcesChart client:visible sources={sources} title="📊 Job Sources" />
          </div>
        </div>

        <!-- Skills Chart + Table -->
        <div class="grid lg:grid-cols-2 gap-8">
          <div>
            <SkillsChart client:visible skills={skills} title="Top Skills in Demand" />
          </div>
          
          <!-- Skills Table -->
          <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-6">
            <h3 class="font-semibold text-lg text-slate-900 dark:text-white mb-4">Skills Breakdown</h3>
            <div class="space-y-3">
              {skills.map((skill, index) => (
                <div class="flex items-center gap-3">
                  <div class="w-6 text-sm text-slate-400 text-right">{index + 1}</div>
                  <div class="flex-1 bg-slate-100 dark:bg-slate-700 rounded-full h-2 overflow-hidden">
                    <div 
                      class="h-full bg-primary-500 rounded-full"
                      style={`width: ${(skill.count / skills[0].count) * 100}%`}
                    ></div>
                  </div>
                  <div class="w-24 text-sm font-medium text-slate-900 dark:text-white truncate">{skill.name}</div>
                  <div class="w-8 text-sm text-slate-500 text-right">{skill.count}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
        
        <!-- Insights -->
        <div class="mt-8 bg-gradient-to-r from-primary-50 to-blue-50 dark:from-primary-900/20 dark:to-blue-900/20 rounded-xl p-6 border border-primary-200 dark:border-primary-800">
          <h3 class="font-semibold text-lg text-slate-900 dark:text-white mb-2">📊 Quick Insights</h3>
          <ul class="space-y-2 text-slate-600 dark:text-slate-300">
            <li>• <strong>{skills[0]?.name}</strong> is the most in-demand skill right now</li>
            <li>• <strong>{Math.round((summary?.remoteJobsCount || 0) / (summary?.totalJobs || 1) * 100)}%</strong> of jobs offer remote work options</li>
            <li>• Average salary across all positions is <strong>{formatSalary(summary?.averageSalary || 0)}</strong></li>
            {salaryStats && (
              <li>• Salary range spans from <strong>{formatSalary(salaryStats.minSalary)}</strong> to <strong>{formatSalary(salaryStats.maxSalary)}</strong> with a median of <strong>{formatSalary(salaryStats.medianSalary)}</strong></li>
            )}
          </ul>
        </div>
      </>
    )}
  </div>
</PageLayout>

<script>
  const btn = document.getElementById('refresh-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      btn.textContent = 'Refreshing...';
      btn.setAttribute('disabled', 'true');
      try {
        await fetch('/api/v1/analytics/refresh', { method: 'POST' });
        window.location.reload();
      } catch {
        btn.textContent = 'Refresh Failed';
        setTimeout(() => { btn.textContent = 'Refresh Data'; }, 2000);
      }
    });
  }
</script>
