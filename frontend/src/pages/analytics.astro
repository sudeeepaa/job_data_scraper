---
import PageLayout from "../layouts/PageLayout.astro";
import SkillsChart from "../components/islands/SkillsChart";
import TrendsChart from "../components/islands/TrendsChart";
import SourcesChart from "../components/islands/SourcesChart";
import {
    fetchAnalyticsSummary,
    fetchMarketTrends,
    fetchSalaryStats,
    fetchSourceDistribution,
    fetchSourceHealth,
    fetchTopSkills,
} from "../lib/api";
import type {
    AnalyticsSummary,
    MarketTrend,
    SalaryStats,
    SkillCount,
    SourceDistribution,
    SourceHealth,
} from "../types";

let skills: SkillCount[] = [];
let summary: AnalyticsSummary | null = null;
let trends: MarketTrend[] = [];
let sources: SourceDistribution[] = [];
let salaryStats: SalaryStats | null = null;
let sourceHealth: SourceHealth[] = [];
let error = "";

try {
    const [skillsResponse, summaryResponse, trendsResponse, sourcesResponse, salaryResponse, sourceHealthResponse] = await Promise.all([
        fetchTopSkills(15),
        fetchAnalyticsSummary(),
        fetchMarketTrends(15),
        fetchSourceDistribution(),
        fetchSalaryStats(),
        fetchSourceHealth(),
    ]);

    skills = skillsResponse.data;
    summary = summaryResponse;
    trends = trendsResponse.data;
    sources = sourcesResponse.data;
    salaryStats = salaryResponse;
    sourceHealth = sourceHealthResponse.data || [];
} catch (e) {
    error = e instanceof Error ? e.message : "Failed to load analytics";
}

const formatSalary = (amount: number) =>
    new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
        maximumFractionDigits: 0,
    }).format(amount);
---

<PageLayout title="Analytics" description="Job market analytics and live ingestion health for JobHuntly.">
    <div class="mx-auto max-w-[1180px] px-6 py-12">
        <div class="mb-10 flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-400">Insights</p>
                <h1 class="mt-3 text-5xl font-extrabold tracking-[-0.06em] text-slate-900">Market Analytics</h1>
                <p class="mt-3 text-xl text-slate-500">Monitor ingestion health, salary ranges, and the skills driving the market right now.</p>
            </div>
            <button type="button" id="refresh-btn" class="jh-button px-5 py-4">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Refresh Data
            </button>
        </div>

        {error ? (
            <div class="rounded-[1.5rem] border border-[rgba(255,108,95,0.28)] bg-[rgba(255,108,95,0.08)] p-6 text-center">
                <p class="text-lg font-medium text-[var(--jh-coral)]">{error}</p>
                <p class="mt-2 text-sm text-slate-500">Make sure the backend API is available.</p>
            </div>
        ) : (
            <>
                {sourceHealth.length > 0 && (
                    <section class="mb-8 rounded-[1.75rem] border border-[var(--jh-border)] bg-white p-6 shadow-[0_20px_60px_rgba(37,47,94,0.05)]">
                        <h2 class="text-[1.9rem] font-extrabold tracking-[-0.05em] text-slate-900">Source Health</h2>
                        <p class="mt-2 text-base text-slate-500">See which ingestion sources are healthy before trusting a fresh search result.</p>
                        <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                            {sourceHealth.map((item) => (
                                <article class="rounded-[1.4rem] border border-[var(--jh-border)] bg-[var(--jh-surface)] p-5">
                                    <div class="flex items-center justify-between gap-3">
                                        <h3 class="text-xl font-bold tracking-[-0.04em] text-slate-900">{item.name}</h3>
                                        <span
                                            class:list={[
                                                "rounded-full px-3 py-1 text-sm font-semibold",
                                                item.healthy ? "bg-[rgba(88,214,190,0.14)] text-[var(--jh-mint)]" : "bg-[rgba(255,108,95,0.1)] text-[var(--jh-coral)]",
                                            ]}
                                        >
                                            {item.healthy ? "Healthy" : "Needs attention"}
                                        </span>
                                    </div>
                                    <dl class="mt-4 space-y-2 text-sm text-slate-500">
                                        <div class="flex justify-between gap-4">
                                            <dt>Last result</dt>
                                            <dd class="font-semibold text-slate-700">{item.resultCount} jobs</dd>
                                        </div>
                                        <div class="flex justify-between gap-4">
                                            <dt>Last duration</dt>
                                            <dd class="font-semibold text-slate-700">{item.lastDuration || "n/a"}</dd>
                                        </div>
                                        <div class="flex justify-between gap-4">
                                            <dt>Last query</dt>
                                            <dd class="max-w-[14rem] truncate font-semibold text-slate-700">{item.lastQuery || "n/a"}</dd>
                                        </div>
                                    </dl>
                                    {item.lastError && <p class="mt-4 text-sm text-[var(--jh-coral)]">{item.lastError}</p>}
                                </article>
                            ))}
                        </div>
                    </section>
                )}

                {summary && (
                    <section class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                        <div class="jh-metric-card">
                            <div class="mb-1 text-sm text-slate-500">Total Jobs</div>
                            <div class="text-3xl font-bold text-slate-900">{summary.totalJobs}</div>
                        </div>
                        <div class="jh-metric-card">
                            <div class="mb-1 text-sm text-slate-500">Companies</div>
                            <div class="text-3xl font-bold text-slate-900">{summary.totalCompanies}</div>
                        </div>
                        <div class="jh-metric-card">
                            <div class="mb-1 text-sm text-slate-500">Average Salary</div>
                            <div class="text-3xl font-bold text-[var(--jh-mint)]">{formatSalary(summary.averageSalary)}</div>
                        </div>
                        <div class="jh-metric-card">
                            <div class="mb-1 text-sm text-slate-500">Remote Jobs</div>
                            <div class="text-3xl font-bold text-slate-900">{summary.remoteJobsCount}</div>
                            <div class="text-sm text-slate-500">({Math.round((summary.remoteJobsCount / summary.totalJobs) * 100)}% of total)</div>
                        </div>
                        <div class="jh-metric-card">
                            <div class="mb-1 text-sm text-slate-500">Posted This Week</div>
                            <div class="text-3xl font-bold text-[var(--jh-primary)]">{summary.jobsThisWeek}</div>
                        </div>
                        <div class="jh-metric-card">
                            <div class="mb-1 text-sm text-slate-500">Posted Today</div>
                            <div class="text-3xl font-bold text-slate-900">{summary.jobsToday}</div>
                        </div>
                    </section>
                )}

                {salaryStats && (
                    <section class="mb-8">
                        <h2 class="mb-4 text-[1.8rem] font-extrabold tracking-[-0.05em] text-slate-900">Salary Overview</h2>
                        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                            <div class="rounded-[1.4rem] border border-[rgba(88,214,190,0.18)] bg-[rgba(88,214,190,0.08)] p-6">
                                <div class="mb-1 text-sm text-slate-500">Minimum</div>
                                <div class="text-2xl font-bold text-slate-900">{formatSalary(salaryStats.minSalary)}</div>
                            </div>
                            <div class="rounded-[1.4rem] border border-[rgba(88,214,190,0.18)] bg-[rgba(88,214,190,0.08)] p-6">
                                <div class="mb-1 text-sm text-slate-500">Maximum</div>
                                <div class="text-2xl font-bold text-slate-900">{formatSalary(salaryStats.maxSalary)}</div>
                            </div>
                            <div class="rounded-[1.4rem] border border-[rgba(88,214,190,0.18)] bg-[rgba(88,214,190,0.08)] p-6">
                                <div class="mb-1 text-sm text-slate-500">Median</div>
                                <div class="text-2xl font-bold text-slate-900">{formatSalary(salaryStats.medianSalary)}</div>
                            </div>
                            <div class="rounded-[1.4rem] border border-[rgba(88,214,190,0.18)] bg-[rgba(88,214,190,0.08)] p-6">
                                <div class="mb-1 text-sm text-slate-500">With Salary Data</div>
                                <div class="text-2xl font-bold text-slate-900">{salaryStats.totalWithSalary} jobs</div>
                            </div>
                        </div>
                    </section>
                )}

                <div class="mb-8 grid gap-8 lg:grid-cols-3">
                    <div class="lg:col-span-2">
                        <TrendsChart client:visible trends={trends} title="Trending Skills (with salary data)" />
                    </div>
                    <div>
                        <SourcesChart client:visible sources={sources} title="Job Sources" />
                    </div>
                </div>

                <div class="grid gap-8 lg:grid-cols-2">
                    <div>
                        <SkillsChart client:visible skills={skills} title="Top Skills in Demand" />
                    </div>

                    <div class="jh-card p-6">
                        <h3 class="mb-4 text-xl font-semibold text-slate-900">Skills Breakdown</h3>
                        <div class="space-y-3">
                            {skills.map((skill, index) => (
                                <div class="flex items-center gap-3">
                                    <div class="w-6 text-right text-sm text-slate-400">{index + 1}</div>
                                    <div class="h-2 flex-1 overflow-hidden rounded-full bg-slate-100">
                                        <div class="h-full rounded-full bg-[var(--jh-primary)]" style={`width: ${(skill.count / skills[0].count) * 100}%`}></div>
                                    </div>
                                    <div class="w-24 truncate text-sm font-medium text-slate-900">{skill.name}</div>
                                    <div class="w-8 text-right text-sm text-slate-500">{skill.count}</div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>

                <div class="mt-8 rounded-[1.75rem] border border-[var(--jh-border)] bg-[linear-gradient(135deg,rgba(99,91,255,0.08)_0%,rgba(63,167,255,0.08)_100%)] p-6">
                    <h3 class="mb-2 text-lg font-semibold text-slate-900">Quick Insights</h3>
                    <ul class="space-y-2 text-slate-600">
                        <li>• <strong>{skills[0]?.name}</strong> is the most in-demand skill right now</li>
                        <li>• <strong>{Math.round((summary?.remoteJobsCount || 0) / (summary?.totalJobs || 1) * 100)}%</strong> of jobs offer remote work options</li>
                        <li>• Average salary across all positions is <strong>{formatSalary(summary?.averageSalary || 0)}</strong></li>
                        {salaryStats && (
                            <li>
                                • Salary range spans from <strong>{formatSalary(salaryStats.minSalary)}</strong> to <strong>{formatSalary(salaryStats.maxSalary)}</strong> with a median of{" "}
                                <strong>{formatSalary(salaryStats.medianSalary)}</strong>
                            </li>
                        )}
                    </ul>
                </div>
            </>
        )}
    </div>
</PageLayout>

<script>
    const btn = document.getElementById("refresh-btn");
    if (btn) {
        btn.addEventListener("click", async () => {
            btn.textContent = "Refreshing...";
            btn.setAttribute("disabled", "true");
            try {
                await fetch("/api/v1/analytics/refresh", { method: "POST" });
                window.location.reload();
            } catch {
                btn.textContent = "Refresh Failed";
                setTimeout(() => {
                    btn.textContent = "Refresh Data";
                    btn.removeAttribute("disabled");
                }, 2000);
            }
        });
    }
</script>
